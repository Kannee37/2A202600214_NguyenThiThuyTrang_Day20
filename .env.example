# Required if using a real LLM provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Local LLM option. Use mock for fast tests, llama_server for a running llama.cpp server,
# or llama_cpp for direct in-process GGUF loading via llama-cpp-python.
LLM_PROVIDER=mock
LLAMA_SERVER_URL=http://127.0.0.1:8080
LLAMA_SERVER_MODEL=local-gguf
LLAMA_CPP_MODEL_PATH=
LLAMA_CPP_N_CTX=4096
LLAMA_CPP_N_THREADS=8
LLAMA_CPP_MAX_TOKENS=512

# Optional tracing providers
TRACE_PROVIDER=local
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=multi-agent-research-lab
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Optional search provider
TAVILY_API_KEY=

# Runtime config
APP_ENV=local
LOG_LEVEL=INFO
MAX_ITERATIONS=6
TIMEOUT_SECONDS=60
